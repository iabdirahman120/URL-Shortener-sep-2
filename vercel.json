{
  "version": 2,
  "buildCommand": "cd Fe && npm install && npm run build",
  "outputDirectory": "Fe/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/r/:short_code", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
